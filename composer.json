{
    "name": "laikait/laika-shield",
    "description": "A powerful firewall middleware package for the Laika PHP Framework — IP filtering, rate limiting, SQL injection & XSS detection, and request filtering.",
    "type": "package",
    "license": "MIT",
    "keywords": [
        "laika",
        "firewall",
        "security",
        "middleware",
        "ip-blocking",
        "rate-limiting",
        "sql-injection",
        "xss",
        "php"
    ],
    "authors": [
        {
            "name": "Laika IT",
            "email": "strblackhawk@gmail.com"
        },
        {
            "name": "SHowket Ahmed",
            "email": "riyadhtayf@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Laika\\Shield\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Laika\\Shield\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
